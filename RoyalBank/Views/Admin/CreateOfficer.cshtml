@model CreateOfficerViewModel
@{ ViewData["Title"] = "Create Officer"; }

<div class="page-heading">
    <h5><i class="fas fa-user-plus me-2"></i>Create Officer Account</h5>
    <a asp-action="Dashboard" asp-controller="Admin" class="btn btn-sm btn-outline-secondary">Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="rb-card">
            <form asp-action="CreateOfficer" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold">Full Name<span class="text-danger">*</span></label>
                    <input asp-for="FullName" class="form-control" placeholder="Officer full name" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email (Login Username) <span class="text-danger">*</span></label>
                    <input asp-for="Email" class="form-control" placeholder="officer@royalbank.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold">Password<span class="text-danger">*</span></label>
                    <input asp-for="Password" class="form-control" placeholder="Minimum 6 characters" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Role <span class="text-danger">*</span></label>
                    <div class="row g-3">
                        <div class="col-6">
                            <label class="w-100">
                                <input type="radio" asp-for="Role" value="KYC" class="d-none" />
                                <div class="account-type-card">
                                    <i class="fas fa-id-card fa-2x text-info mb-2 d-block"></i>
                                    <strong>KYC Officer</strong>
                                    <p class="text-muted small mb-0 mt-1">Verifies documents</p>
                                </div>
                            </label>
                        </div>
                        <div class="col-6">
                            <label class="w-100">
                                <input type="radio" asp-for="Role" value="Compliance" class="d-none" />
                                <div class="account-type-card">
                                    <i class="fas fa-shield-alt fa-2x text-warning mb-2 d-block"></i>
                                    <strong>Compliance Officer</strong>
                                    <p class="text-muted small mb-0 mt-1">Approves accounts</p>
                                </div>
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="Role" class="field-validation-error d-block mt-2"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="fas fa-plus-circle me-2"></i>Create Officer
                </button>
            </form>
        </div>
    </div>
</div>
