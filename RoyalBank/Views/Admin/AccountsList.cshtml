@model List<Account>
@{ ViewData["Title"] = "Accounts List"; }

<div class="page-heading">
    <h5><i class="fas fa-list me-2"></i>All Bank Accounts</h5>
</div>

<div class="rb-card">
    <div class="card-title"><span><i class="fas fa-piggy-bank me-2"></i>Account Registry (@Model.Count total)</span></div>

    @if (!Model.Any())
    {
        <p class="text-muted">No accounts found.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table rb-table">
                <thead>
                    <tr>
                        <th>#</th><th>Customer</th><th>Email</th><th>Type</th>
                        <th>Created</th><th>Risk</th><th>Status</th><th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model)
                    {
                        string ac = a.AccountStatus == AccountStatus.ACTIVE    ? "badge-active"
                                  : a.AccountStatus == AccountStatus.REJECTED   ? "badge-rejected"
                                  : a.AccountStatus == AccountStatus.INACTIVE   ? "bg-secondary"
                                  : "badge-pending";
                        <tr>
                            <td>@a.AccountId</td>
                            <td><strong>@(a.Customer?.FullName ?? "—")</strong></td>
                            <td><small>@(a.Customer?.Email ?? "—")</small></td>
                            <td>@a.AccountType</td>
                            <td>@a.CreatedDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (a.Customer?.RiskProfile != null)
                                {
                                    string rc = a.Customer.RiskProfile.RiskLevel == RiskLevel.LOW  ? "badge-low"
                                              : a.Customer.RiskProfile.RiskLevel == RiskLevel.HIGH ? "badge-high"
                                              : "badge-medium";
                                    <span class="badge @rc">@a.Customer.RiskProfile.RiskLevel</span>
                                }
                                else { <span class="badge bg-secondary">N/A</span> }
                            </td>
                            <td><span class="badge @ac">@a.AccountStatus.ToString().Replace("_"," ")</span></td>
                            <td>
                                @if (a.AccountStatus == AccountStatus.ACTIVE)
                                {
                                    <form asp-action="DeactivateAccount" asp-controller="Admin" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@a.AccountId" />
                                        <button type="submit" class="btn btn-sm btn-warning"
                                                onclick="return confirm('Deactivate account #@a.AccountId?')">
                                            <i class="fas fa-ban me-1"></i>Deactivate
                                        </button>
                                    </form>
                                }
                                else if (a.AccountStatus == AccountStatus.INACTIVE)
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
