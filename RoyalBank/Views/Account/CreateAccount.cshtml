@model CreateAccountViewModel
@{
    ViewData["Title"] = "Create Account";
    bool hasSavings = ViewBag.HasSavings ?? false;
    bool hasCurrent = ViewBag.HasCurrent ?? false;
}

<div class="page-heading">
    <h5><i class="fas fa-piggy-bank me-2"></i>Create Bank Account</h5>
    <a asp-action="Dashboard" asp-controller="Customer" class="btn btn-sm btn-outline-secondary">Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="rb-card">
            <div class="note-success mb-3">
                <i class="fas fa-check-circle me-2"></i>
                Your KYC is verified. Select an account type below.
                Each customer can have <strong>one Savings</strong> and <strong>one Current</strong> account.
            </div>

            <form asp-action="CreateAccount" asp-controller="Account" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Select Account Type <span class="text-danger">*</span></label>
                    <div class="row g-3">
                        <div class="col-6">
                            @if (hasSavings)
                            {
                                <!-- Already has savings - disabled -->
                                <div class="account-type-card" style="opacity:0.5; cursor:not-allowed;">
                                    <i class="fas fa-piggy-bank fa-2x text-secondary mb-2 d-block"></i>
                                    <strong>Savings</strong>
                                    <p class="text-muted small mb-0 mt-1">Already created</p>
                                </div>
                            }
                            else
                            {
                                <label class="w-100">
                                    <input type="radio" asp-for="AccountType" value="Savings" class="d-none" />
                                    <div class="account-type-card">
                                        <i class="fas fa-piggy-bank fa-2x text-success mb-2 d-block"></i>
                                        <strong>Savings</strong>
                                        <p class="text-muted small mb-0 mt-1">Earn interest on deposits</p>
                                    </div>
                                </label>
                            }
                        </div>
                        <div class="col-6">
                            @if (hasCurrent)
                            {
                                <!-- Already has current - disabled -->
                                <div class="account-type-card" style="opacity:0.5; cursor:not-allowed;">
                                    <i class="fas fa-briefcase fa-2x text-secondary mb-2 d-block"></i>
                                    <strong>Current</strong>
                                    <p class="text-muted small mb-0 mt-1">Already created</p>
                                </div>
                            }
                            else
                            {
                                <label class="w-100">
                                    <input type="radio" asp-for="AccountType" value="Current" class="d-none" />
                                    <div class="account-type-card">
                                        <i class="fas fa-briefcase fa-2x text-primary mb-2 d-block"></i>
                                        <strong>Current</strong>
                                        <p class="text-muted small mb-0 mt-1">For frequent transactions</p>
                                    </div>
                                </label>
                            }
                        </div>
                    </div>
                    <span asp-validation-for="AccountType" class="field-validation-error d-block mt-2"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="fas fa-plus-circle me-2"></i>Create Account
                </button>
            </form>
        </div>
    </div>
</div>
