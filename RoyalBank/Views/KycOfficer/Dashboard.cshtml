@model List<KycDocument>
@{ ViewData["Title"] = "KYC Officer Dashboard"; }

<div class="page-heading">
    <h5><i class="fas fa-id-card-alt me-2"></i>KYC Officer Dashboard</h5>
</div>

<div class="row g-3 mb-3">
    <div class="col-6 col-md-3">
        <div class="stat-card"><div class="lbl">Total Documents</div><div class="val">@Model.Count</div></div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-left-color:#ffc107">
            <div class="lbl">Pending</div>
            <div class="val">@Model.Count(d => d.VerificationStatus == VerificationStatus.PENDING)</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-left-color:#28a745">
            <div class="lbl">Verified</div>
            <div class="val">@Model.Count(d => d.VerificationStatus == VerificationStatus.VERIFIED)</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card" style="border-left-color:#dc3545">
            <div class="lbl">Rejected</div>
            <div class="val">@Model.Count(d => d.VerificationStatus == VerificationStatus.REJECTED)</div>
        </div>
    </div>
</div>

<div class="rb-card">
    <div class="card-title"><span><i class="fas fa-list me-2"></i>Customer Documents</span></div>

    @if (!Model.Any())
    {
        <div class="upload-area">
            <i class="fas fa-inbox fa-2x text-muted mb-2"></i>
            <p class="text-muted mb-0">No documents submitted yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table rb-table">
                <thead>
                    <tr>
                        <th>#</th><th>Customer</th><th>Document Type</th>
                        <th>Uploaded</th><th>Status</th><th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in Model)
                    {
                        string bc = doc.VerificationStatus == VerificationStatus.VERIFIED ? "badge-verified"
                                  : doc.VerificationStatus == VerificationStatus.REJECTED  ? "badge-rejected"
                                  : "badge-pending";
                        <tr>
                            <td>@doc.DocumentId</td>
                            <td>
                                <strong>@(doc.Customer?.FullName ?? "—")</strong><br />
                                <small class="text-muted">@doc.Customer?.Email</small>
                            </td>
                            <td>@doc.DocumentType</td>
                            <td>@doc.UploadedAt.ToString("dd MMM yyyy")</td>
                            <td><span class="badge @bc">@doc.VerificationStatus</span></td>
                            <td>
                                <a asp-action="VerifyDocument" asp-controller="KycOfficer"
                                   asp-route-id="@doc.DocumentId" class="btn btn-sm btn-primary">
                                    <i class="fas fa-eye me-1"></i>Review
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
