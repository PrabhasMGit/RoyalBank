@model RegisterViewModel
@{ Layout = null; ViewData["Title"] = "Register"; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Register - Royal Bank</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<div class="auth-wrapper py-4">
    <div class="auth-card" style="max-width:540px;">
        <div class="logo">
            <i class="fas fa-user-plus"></i>
            <h4>Royal Bank</h4>
            <p>Customer Registration — Step 1 of 2</p>
        </div>

        <form asp-action="Register" asp-controller="Customer" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small mb-3"></div>

            <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold">Full Name<span class="text-danger">*</span></label>
                <input asp-for="FullName" class="form-control" placeholder="John Doe" />
                <span asp-validation-for="FullName" class="field-validation-error"></span>
            </div>

            <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold">Email<span class="text-danger">*</span></label>
                <input asp-for="Email" class="form-control" placeholder="john@example.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                        <label asp-for="MobileNumber" class="form-label fw-semibold">Mobile Number<span class="text-danger">*</span></label>
                    <input asp-for="MobileNumber" class="form-control" placeholder="9876543210" />
                    <span asp-validation-for="MobileNumber" class="field-validation-error"></span>
                    <small class="text-muted">Start with 6-9, 10 digits</small>
                </div>
                <div class="col-md-6 mb-3">
                        <label asp-for="DateOfBirth" class="form-label fw-semibold">Date of Birth<span class="text-danger">*</span></label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" />
                    <span asp-validation-for="DateOfBirth" class="field-validation-error"></span>
                    <small class="text-muted">Must be 18+</small>
                </div>
            </div>

            <div class="mb-3">
                    <label asp-for="Address" class="form-label fw-semibold">Address<span class="text-danger">*</span></label>
                <textarea asp-for="Address" class="form-control" rows="2" placeholder="Full residential address"></textarea>
                <span asp-validation-for="Address" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                    <label asp-for="Income" class="form-label fw-semibold">Annual Income (Rs.)<span class="text-danger">*</span></label>
                <input asp-for="Income" type="number" class="form-control" placeholder="500000" min="1000" />
                <span asp-validation-for="Income" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                <i class="fas fa-arrow-right me-2"></i>Continue — Set Password
            </button>
        </form>

        <hr class="my-3" />
        <p class="text-center small text-muted">
            Already registered? <a asp-controller="Home" asp-action="Login" class="fw-semibold">Login here</a>
        </p>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
